<!DOCTYPE html>f
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rhys's company - Central PA</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    .hero-bg {
      background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.75)), url('https://picsum.photos/id/1015/2000/1200');
      background-size: cover;
      background-position: center;
    }
    .search-result { transition: all 0.3s; }
  </style>
</head>
<body class="font-sans bg-gray-50">

  <!-- Navigation -->
  <nav class="bg-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-5">
      <div class="flex justify-between items-center">
        <div class="text-3xl font-bold text-blue-600">Rhys's company</div>
        
        <!-- Search Bar -->
        <div class="flex-1 max-w-md mx-8">
          <div class="relative">
            <input 
              id="searchInput"
              type="text" 
              placeholder="Search services, articles, or projects..." 
              class="w-full pl-12 pr-6 py-3 border border-gray-300 rounded-full focus:outline-none focus:border-blue-500 text-sm"
              onkeyup="liveSearch()">
            <i class="fa-solid fa-magnifying-glass absolute left-5 top-1/2 -translate-y-1/2 text-gray-400"></i>
          </div>
        </div>

        <div class="hidden md:flex items-center space-x-8 text-sm font-medium">
          <a href="#home" class="hover:text-blue-600 transition">Home</a>
          <a href="#services" class="hover:text-blue-600 transition">Services</a>
          <a href="#portfolio" class="hover:text-blue-600 transition">Portfolio</a>
          <a href="#blog" class="hover:text-blue-600 transition">Blog</a>
          <a href="#contact" class="hover:text-blue-600 transition">Contact</a>
        </div>
        
        <button onclick="toggleMenu()" class="md:hidden text-3xl">☰</button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobileMenu" class="hidden md:hidden bg-white border-b shadow">
    <div class="flex flex-col px-6 py-6 space-y-5 text-lg">
      <a href="#home" onclick="toggleMenu()">Home</a>
      <a href="#services" onclick="toggleMenu()">Services</a>
      <a href="#portfolio" onclick="toggleMenu()">Portfolio</a>
      <a href="#blog" onclick="toggleMenu()">Blog</a>
      <a href="#contact" onclick="toggleMenu()">Contact</a>
    </div>
  </div>

  <!-- Hero -->
  <section id="home" class="hero-bg h-screen flex items-center text-white">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
        Expert Local Services in Central PA
      </h1>
      <p class="text-2xl mb-10 max-w-2xl mx-auto">
        Reliable, professional solutions for your home or business in Paxtonia, Harrisburg & surrounding areas.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="#contact" class="bg-blue-600 hover:bg-blue-700 px-10 py-5 rounded-2xl text-xl font-semibold transition">Get Free Quote Today</a>
        <a href="tel:7175551234" class="border-2 border-white hover:bg-white hover:text-blue-900 px-10 py-5 rounded-2xl text-xl font-semibold transition">Call (717) 555-1234</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-5xl font-bold mb-4">Our Services</h2>
        <p class="text-xl text-gray-600">What we offer to local customers</p>
      </div>
      
      <div id="servicesGrid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service cards will be filtered by search -->
        <div class="service-card bg-white p-8 rounded-3xl shadow hover:shadow-2xl transition group">
          <i class="fa-solid fa-plumbing text-5xl text-blue-600 mb-6"></i>
          <h3 class="text-2xl font-semibold mb-3">Plumbing Repair</h3>
          <p class="text-gray-600">Leaky pipes, water heaters, drain cleaning and full installations.</p>
        </div>
        
        <div class="service-card bg-white p-8 rounded-3xl shadow hover:shadow-2xl transition group">
          <i class="fa-solid fa-fan text-5xl text-blue-600 mb-6"></i>
          <h3 class="text-2xl font-semibold mb-3">HVAC Services</h3>
          <p class="text-gray-600">Heating, cooling, maintenance and emergency repairs.</p>
        </div>
        
        <div class="service-card bg-white p-8 rounded-3xl shadow hover:shadow-2xl transition group">
          <i class="fa-solid fa-home text-5xl text-blue-600 mb-6"></i>
          <h3 class="text-2xl font-semibold mb-3">Home Renovation</h3>
          <p class="text-gray-600">Kitchen, bathroom, flooring and complete remodels.</p>
        </div>
        <!-- Add more service cards as needed -->
      </div>
    </div>
  </section>

  <!-- Portfolio / Gallery -->
  <section id="portfolio" class="py-24 bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-5xl font-bold text-center mb-16">Recent Projects</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="rounded-3xl overflow-hidden">
          <img src="https://picsum.photos/id/201/600/400" alt="Project 1" class="w-full h-64 object-cover">
          <div class="p-6">
            <h4 class="font-semibold text-xl">Full Kitchen Remodel</h4>
            <p class="text-gray-400">Harrisburg, PA • 2025</p>
          </div>
        </div>
        <!-- Add more portfolio items -->
      </div>
    </div>
  </section>

  <!-- Blog / Articles -->
  <section id="blog" class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-5xl font-bold text-center mb-4">Latest Articles</h2>
      <p class="text-center text-gray-600 mb-16">Tips and insights from our team</p>
      
      <div id="blogGrid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
        <div class="blog-card bg-white rounded-3xl overflow-hidden shadow hover:shadow-xl transition">
          <img src="https://picsum.photos/id/237/600/300" alt="" class="w-full h-48 object-cover">
          <div class="p-8">
            <h3 class="font-semibold text-2xl mb-3">How to Prevent Frozen Pipes This Winter</h3>
            <p class="text-gray-600 line-clamp-3">Simple steps every homeowner in Central PA should know...</p>
          </div>
        </div>
        <!-- More blog cards can be added here -->
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-24 bg-blue-900 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <h2 class="text-5xl font-bold mb-8">Let's Work Together</h2>
          <p class="text-2xl mb-10">Tell us about your project and we'll get back to you fast.</p>
          <!-- Contact details -->
        </div>
        <form class="space-y-8">
          <!-- Form fields here (same as previous version) -->
          <button type="button" onclick="submitForm()" 
            class="w-full bg-white text-blue-900 py-5 rounded-2xl font-bold text-xl hover:bg-gray-100">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

  <footer class="bg-black text-gray-400 py-12">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="text-2xl font-semibold text-white mb-2">Rhys's company</p>
      <p>Serving Paxtonia, Harrisburg & Central Pennsylvania</p>
      <p class="mt-8">&copy; 2026 All Rights Reserved</p>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    function toggleMenu() {
      document.getElementById('mobileMenu').classList.toggle('hidden');
    }

    // Live Search Function
    function liveSearch() {
      const query = document.getElementById('searchInput').value.toLowerCase().trim();
      
      // Search in service cards
      document.querySelectorAll('.service-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) || query === '' ? 'block' : 'none';
      });

      // Search in blog cards
      document.querySelectorAll('.blog-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) || query === '' ? 'block' : 'none';
      });
    }

    // Simple form submission alert (replace with real backend later)
    function submitForm() {
      alert("Thank you! Your message has been received. (This is a demo – connect to Formspree or EmailJS for real emails)");
    }

    // Smooth scrolling
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>
</body>
</html>
